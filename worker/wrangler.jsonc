{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "astrbot-group-daily-analysis-web-report",
  "main": "src/index.py",
  "compatibility_date": "2026-03-29",
  "compatibility_flags": [
    "python_workers"
  ],
  "assets": {
    "directory": "./templates",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "vars": {
    "UPLOAD_TOKEN": "change-me"
  },
  "kv_namespaces": [
    {
      "binding": "REPORTS"
    }
  ]
}
