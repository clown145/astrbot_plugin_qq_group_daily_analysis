{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "astrbot-daily-report-worker",
  "main": "worker/src/index.ts",
  "compatibility_date": "2026-03-29",
  "kv_namespaces": [
    {
      "binding": "REPORTS",
      "id": "REPLACE_WITH_YOUR_KV_NAMESPACE_ID"
    }
  ],
  "vars": {
    "DEFAULT_TTL_SECONDS": "604800",
    "PUBLIC_BASE_URL": ""
  }
}
